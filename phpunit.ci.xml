<?xml version="1.0" encoding="UTF-8"?>
<!--
    CI unit suite: pure-logic tests that run on a vanilla PHP runner without a
    Magento install or the Twig library. PriceExtensionTest needs both (Twig +
    Magento Pricing types) and is excluded here; it runs in a real Magento root
    (see phpunit.xml).
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         bootstrap="src/Test/Unit/bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnWarning="true"
         failOnRisky="true">
    <testsuites>
        <testsuite name="MageObsidian Storefront Standalone Unit">
            <directory>src/Test/Unit</directory>
            <exclude>src/Test/Unit/Model/Template/Extension/PriceExtensionTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/NavigationTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/StoreSwitcherTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/CurrencySwitcherTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/FeaturedCategoriesTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/DirectoryDataTest.php</exclude>
        </testsuite>
    </testsuites>
</phpunit>
